{
    "buildCommand": "rm -f packages/core/tsconfig.tsbuildinfo && npm --workspace @papergrid/core run build && npm --workspace @papergrid/web run build",
    "outputDirectory": "packages/web/dist",
    "installCommand": "npm install --include=dev --include=optional",
    "framework": null,
    "redirects": [
        { "source": "/blog", "destination": "/", "permanent": false },
        { "source": "/blog/:path*", "destination": "/", "permanent": false }
    ],
    "rewrites": [
        { "source": "/(.*)", "destination": "/index.html" }
    ]
}
