# Production API URL — points to the Convex HTTP endpoint
VITE_API_URL=https://veracious-pony-145.convex.site

# Paper types not yet ready for production. Comma-separated.
# These show as "Coming Soon" tiles in the paper picker; existing pages of
# these types render a friendly placeholder instead of their unfinished UI.
# Remove an entry from this list to ship that paper type.
VITE_COMING_SOON_PAPERS=hex,isometric,music
