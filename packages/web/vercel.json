{
    "buildCommand": "cd ../.. && npm --workspace @papergrid/core run build && npm --workspace @papergrid/web run build",
    "outputDirectory": "dist",
    "installCommand": "cd ../.. && npm install --include=dev --include=optional",
    "framework": "vite",
    "redirects": [
        {
            "source": "/blog",
            "destination": "/",
            "permanent": false
        },
        {
            "source": "/blog/:path*",
            "destination": "/",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
