{
    "buildCommand": "cd ../.. && npm --workspace @papergrid/core run build && npm --workspace @papergrid/web run build",
    "outputDirectory": "dist",
    "installCommand": "cd ../.. && npm install --include=dev --include=optional",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}