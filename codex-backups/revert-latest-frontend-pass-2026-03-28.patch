+
+function getAiApiBase(): string {
+  if (
+    import.meta.env.DEV &&
+    typeof window !== 'undefined' &&
+    (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1')
+  ) {
+    // In local dev, prefer Vite's same-origin AI proxy so cover/layout generation
+    // keeps working even when the remote backend CORS policy is stricter.
+    return '';
